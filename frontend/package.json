{
  "name": "@quizmaker/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build --workspace @quizmaker/shared && tsc -b && vite build",
    "typecheck": "npm run build --workspace @quizmaker/shared && tsc -b --pretty false",
    "test": "npm run build --workspace @quizmaker/shared && vitest run"
  },
  "dependencies": {
    "@quizmaker/shared": "file:../shared",
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "vitest": "^4.1.9"
  }
}
