{
  "name": "@quizmaker/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:watch": "tsx watch src/server.ts",
    "build": "npm run build --workspace @quizmaker/shared && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "npm run build --workspace @quizmaker/shared && tsc -p tsconfig.json --noEmit",
    "test": "npm run build --workspace @quizmaker/shared && vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@quizmaker/shared": "file:../shared",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "vitest": "^4.1.9"
  }
}
